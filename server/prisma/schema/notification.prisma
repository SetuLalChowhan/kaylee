model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  isSeen      Boolean  @default(false)
  type        String   @default("INFO")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
