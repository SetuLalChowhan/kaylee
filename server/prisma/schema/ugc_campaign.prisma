model UgcCampaign {
  id            String               @id @default(uuid())
  userId        String
  name          String
  brandName     String
  deadline      String
  amount        String
  status        String               @default("Draft")
  releaseFiles  Boolean              @default(false)
  notes         String?
  slug          String               @unique
  paymentStatus String               @default("Pending")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tasks         UgcCampaignTask[]
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliverables  UgcDeliverable[]
  documents     UgcDocument[]
  feedback      UgcFeedbackMessage[]
  media         UgcMedia[]
  notesComments UgcNote[]

  @@map("ugc_campaigns")
}

model UgcDeliverable {
  id         String      @id @default(uuid())
  campaignId String
  text       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  campaign   UgcCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ugc_deliverables")
}

model UgcCampaignTask {
  id            String      @id @default(uuid())
  campaignId    String
  name          String
  date          String
  completed     Boolean     @default(false)
  plannerTaskId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  campaign      UgcCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ugc_campaign_tasks")
}

model UgcMedia {
  id           String               @id @default(uuid())
  campaignId   String
  name         String
  originalName String?
  type         String
  url          String
  description  String?
  status       String               @default("pending")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  feedback     UgcFeedbackMessage[]
  campaign     UgcCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ugc_media")
}

model UgcDocument {
  id           String      @id @default(uuid())
  campaignId   String
  name         String
  originalName String?
  url          String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  campaign     UgcCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ugc_documents")
}

model UgcNote {
  id         String      @id @default(uuid())
  campaignId String
  text       String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  campaign   UgcCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ugc_notes")
}

model UgcFeedbackMessage {
  id         String      @id @default(uuid())
  campaignId String
  text       String
  from       String
  mediaId    String?
  fileUrl    String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  campaign   UgcCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  media      UgcMedia?   @relation(fields: [mediaId], references: [id])

  @@map("ugc_feedback_messages")
}
